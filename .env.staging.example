# PlayConnect Staging — Environment Configuration
# Copy to .env.staging on the staging server. NEVER commit with real values.
#
# This file is loaded by docker-compose.staging.yml via env_file.

# Application
APP_ENV=staging
NODE_ENV=production
TZ=Asia/Kolkata

# Database (MongoDB — managed or self-hosted)
MONGODB_URI=mongodb://mongo:27017/playconnect_staging?replicaSet=rs0

# Logging
LOG_LEVEL=info

# JWT Authentication (use strong, unique secrets)
JWT_ACCESS_SECRET=CHANGE_ME_staging_access_secret
JWT_REFRESH_SECRET=CHANGE_ME_staging_refresh_secret
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# Password Hashing
BCRYPT_COST=12

# SMTP / Email
SMTP_HOST=smtp.staging.example.com
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=CHANGE_ME
SMTP_PASS=CHANGE_ME
SMTP_FROM=noreply@staging.playconnect.app
EMAIL_DRY_RUN=false
FEE_REMINDER_ENABLED=false

# Admin Web
NEXT_PUBLIC_APP_ENV=staging
API_BASE_URL=http://api:3001

# Docker Registry (for compose variable substitution)
DOCKER_REGISTRY=ghcr.io/playconnect
IMAGE_TAG=staging-latest
