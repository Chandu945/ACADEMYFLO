# Academyflo Staging — Deploy Environment Configuration
# Copy to deploy/.env.staging on the server. NEVER commit with real values.
#
# This file is loaded by deploy/docker-compose.staging.yml via env_file.

# Application
APP_ENV=staging
NODE_ENV=production
TZ=Asia/Kolkata

# Database (MongoDB — managed or self-hosted)
MONGODB_URI=mongodb://mongo:27017/academyflo_staging?replicaSet=rs0

# Logging
LOG_LEVEL=info

# JWT Authentication (use strong, unique secrets)
JWT_ACCESS_SECRET=CHANGE_ME_staging_access_secret
JWT_REFRESH_SECRET=CHANGE_ME_staging_refresh_secret
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# Password Hashing
BCRYPT_COST=12

# SMTP / Email
SMTP_HOST=smtp.staging.example.com
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=CHANGE_ME
SMTP_PASS=CHANGE_ME
SMTP_FROM=noreply@staging.academyflo.com
EMAIL_DRY_RUN=false
FEE_REMINDER_ENABLED=false

# Admin Web
NEXT_PUBLIC_APP_ENV=staging
API_BASE_URL=http://api:3001

# Docker Registry (for compose variable substitution)
DOCKER_REGISTRY=ghcr.io/academyflo
IMAGE_TAG=staging-latest

# Domain & TLS
DOMAIN=staging.academyflo.com
SSL_CERT_PATH=/etc/ssl/certs/academyflo.pem
SSL_KEY_PATH=/etc/ssl/private/academyflo.key

# Secrets Provider
# Options: local (env file), aws-ssm (AWS Systems Manager Parameter Store)
SECRET_PROVIDER=local
