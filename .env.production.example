# PlayConnect Production — Environment Configuration
# Copy to .env.production on the production server. NEVER commit with real values.
#
# This file is loaded by docker-compose.prod.yml via env_file.

# Application
APP_ENV=production
NODE_ENV=production
TZ=Asia/Kolkata

# Database (MongoDB — use a managed service like Atlas for production)
MONGODB_URI=CHANGE_ME_mongodb_connection_string

# Logging
LOG_LEVEL=warn

# JWT Authentication (use strong, unique secrets — different from staging)
JWT_ACCESS_SECRET=CHANGE_ME_production_access_secret
JWT_REFRESH_SECRET=CHANGE_ME_production_refresh_secret
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# Password Hashing
BCRYPT_COST=12

# SMTP / Email
SMTP_HOST=smtp.production.example.com
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=CHANGE_ME
SMTP_PASS=CHANGE_ME
SMTP_FROM=noreply@playconnect.app
EMAIL_DRY_RUN=false
FEE_REMINDER_ENABLED=true

# Admin Web
NEXT_PUBLIC_APP_ENV=production
API_BASE_URL=http://api:3001

# Docker Registry
DOCKER_REGISTRY=ghcr.io/playconnect
IMAGE_TAG=latest
