# Academyflo Production — Environment Configuration
# Copy to .env.production on the production server. NEVER commit with real values.
#
# This file is loaded by docker-compose.prod.yml via env_file.

# Application
APP_ENV=production
NODE_ENV=production
TZ=Asia/Kolkata

# Database (MongoDB — use a managed service like Atlas for production)
# Example: mongodb+srv://USER:PASS@cluster0.mongodb.net/academyflo_prod?replicaSet=rs0&retryWrites=true
MONGODB_URI=<MONGODB_CONNECTION_STRING>

# Logging
LOG_LEVEL=warn

# JWT Authentication (use strong, unique secrets — different from staging)
# Generate each with: openssl rand -base64 48   (must be ≥32 bytes)
JWT_ACCESS_SECRET=<64-CHAR-RANDOM-STRING>
JWT_REFRESH_SECRET=<64-CHAR-RANDOM-STRING-DIFFERENT-FROM-ACCESS>
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# Password Hashing
BCRYPT_COST=12

# SMTP / Email
SMTP_HOST=smtp.production.example.com
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=<SMTP_USERNAME>
SMTP_PASS=<SMTP_PASSWORD>         # Create a dedicated service account; do NOT reuse personal creds
SMTP_FROM=noreply@academyflo.com
EMAIL_DRY_RUN=false
FEE_REMINDER_ENABLED=true

# Admin Web
NEXT_PUBLIC_APP_ENV=production
API_BASE_URL=http://api:3001

# Docker Registry
DOCKER_REGISTRY=ghcr.io/academyflo
IMAGE_TAG=latest
