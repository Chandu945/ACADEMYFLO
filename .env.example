# PlayConnect — Root Environment Policy
# This file documents environment variable conventions.
# Copy to .env for local development. NEVER commit .env files.

# Common
NODE_ENV=development
APP_ENV=development
TZ=Asia/Kolkata

# Secret management strategy:
#   development  — local .env files (not committed)
#   staging      — injected via CI/CD secrets or SECRET_PROVIDER
#   production   — injected via CI/CD secrets or SECRET_PROVIDER
SECRET_PROVIDER=local

# Cloudinary (Image Uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Redis Cache (optional — falls back to in-memory cache if not set)
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=300

# MongoDB read preference (primary, primaryPreferred, secondary, secondaryPreferred, nearest)
MONGODB_READ_PREFERENCE=secondaryPreferred

# OTP / Password Reset
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_COOLDOWN_SECONDS=60
